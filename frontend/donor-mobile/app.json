{
  "expo": {
    "name": "donor-mobile",
    "slug": "donor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.pranko007.donormobile",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "donor-mobile",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow BloodDispatch to use your location to find nearby hospitals during emergencies.",
          "locationWhenInUsePermission": "Allow BloodDispatch to use your location to find nearby hospitals during emergencies."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BloodDispatch to access your photos for your profile picture.",
          "cameraPermission": "Allow BloodDispatch to access your camera for your profile picture."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05b18a38-c9c6-4133-9f96-db43bec875da"
      }
    }
  }
}
