# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file — it's already in .gitignore.

# --- Neo4j AuraDB -------------------------------------------------------
# Get these from console.neo4j.io after creating your AuraDB instance
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-generated-password

# --- Google Geocoding API -----------------------------------------------
# Get this from Google Cloud Console > APIs & Services > Credentials
# Enable the "Geocoding API" for the project first.
GOOGLE_GEOCODING_API_KEY=your-google-api-key-here

# --- Filled in later by backend team (Exotel / Sarvam AI) ---------------
# EXOTEL_API_KEY=
# EXOTEL_API_TOKEN=
# SARVAM_API_KEY=
